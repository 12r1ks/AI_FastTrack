on/"}, "hash": "65aec7c15649f48ca90c1c973bee5eafa09d88823d00c9c3e3f419e37ff6f34e", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "# CityPark \u2014 Parking Facility Information", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 41, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "15cfaf15-28ad-40df-bcd1-e33f6f6e6915": {"__data__": {"id_": "15cfaf15-28ad-40df-bcd1-e33f6f6e6915", "embedding": null, "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9", "node_type": "4", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25"}, "hash": "f938ce3b057cc4cf3d6a9af0a500efc57579a1102372d024cc00dfa79f653a66", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "f168577c-d7c2-44d7-aaea-647513229f3a", "node_type": "1", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/"}, "hash": "448e373cf73a113f7fe93813cbaf6aa4054600c6bda3143abcbadd6a49711366", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "42d0c5aa-8969-4528-8371-e81ee5ca2870", "node_type": "1", "metadata": {"header_path": "/CityPark \u2014 Parking Facility Information/"}, "hash": "5d2c93a20df18c922c01a48af9bdd9646c218b35d8f2cb74bcbdc9fc86748ae7", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "## Overview\n\nCityPark operates two secure parking facilities across Maplewood. Reservations are made exclusively online through the CityPark website. Both facilities operate 24/7.\n\n- **Total capacity:** 20 spots across 2 locations\n- **Reservations:** Online only, via the CityPark website\n- **Access:** 24/7 at both locations", "mimetype": "text/plain", "start_char_idx": 43, "end_char_idx": 368, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "42d0c5aa-8969-4528-8371-e81ee5ca2870": {"__data__": {"id_": "42d0c5aa-8969-4528-8371-e81ee5ca2870", "embedding": null, "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9", "node_type": "4", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25"}, "hash": "f938ce3b057cc4cf3d6a9af0a500efc57579a1102372d024cc00dfa79f653a66", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "15cfaf15-28ad-40df-bcd1-e33f6f6e6915", "node_type": "1", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/"}, "hash": "41f724e9e1d4d1382966cc2599113a2a951608b3b0efe4216b2698ee09d7e5e6", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "60375546-65a1-4c2f-b278-2b5a884c57f0", "node_type": "1", "metadata": {"header_path": "/CityPark \u2014 Parking Facility Information/Location 1 \u2014 CityPark Central/"}, "hash": "24bc6c67888dd5c356c50f39f857a075e059b9b476738d57a3c92d0b78a3652d", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "## Location 1 \u2014 CityPark Central\n\n**Address:** 14 Elm Street, Maplewood, 10001\n**Position:** Heart of the city centre, one block east of Maplewood Town Hall.\n\n**Landmarks:**\n- 50 m from Maplewood Town Hall (east side)\n- Opposite the Elm Street post office\n- Next to the Sunrise Caf\u00e9\n\n**Entrance:** Vehicle gate on Elm Street \u2014 opens automatically when a valid reservation QR code is scanned.\n**Height restriction:** 2.1 m maximum (no trucks or large vans).", "mimetype": "text/plain", "start_char_idx": 371, "end_char_idx": 827, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "60375546-65a1-4c2f-b278-2b5a884c57f0": {"__data__": {"id_": "60375546-65a1-4c2f-b278-2b5a884c57f0", "embedding": null, "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/Location 1 \u2014 CityPark Central/"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9", "node_type": "4", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25"}, "hash": "f938ce3b057cc4cf3d6a9af0a500efc57579a1102372d024cc00dfa79f653a66", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "42d0c5aa-8969-4528-8371-e81ee5ca2870", "node_type": "1", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/"}, "hash": "219c2c25f29a2d741385bc01d2f114ead5596447ec9eb77ac97671df1654f6b2", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "09410bba-e5f3-4f68-8bbe-2eda65a3d8c0", "node_type": "1", "metadata": {"header_path": "/CityPark \u2014 Parking Facility Information/Location 1 \u2014 CityPark Central/"}, "hash": "a1cca75afa469805eecd6d6692a1e4ae2afecf854a8094d5589268ee1505b70b", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "### Parking Spots \u2014 CityPark Central\n\n| Spot | Type        | Description                                      |\n|------|-------------|--------------------------------------------------|\n| A1   | Standard    | Open-air spot, suitable for standard-size cars   |\n| A2   | Standard    | Open-air spot, suitable for standard-size cars   |\n| A3   | Standard    | Open-air spot, suitable for standard-size cars   |\n| A4   | Standard    | Open-air spot, suitable for standard-size cars   |\n| A5   | Standard    | Open-air spot, suitable for standard-size cars   |\n| B1   | Premium     | Covered spot near entrance, suitable for all cars|\n| B2   | Premium     | Covered spot near entrance, suitable for all cars|\n| B3   | Premium     | Covered spot near entrance, suitable for all cars|\n\n**Total: 8 spots** (5 standard, 3 premium). No trucks or vehicles over 2.1 m.", "mimetype": "text/plain", "start_char_idx": 829, "end_char_idx": 1685, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "09410bba-e5f3-4f68-8bbe-2eda65a3d8c0": {"__data__": {"id_": "09410bba-e5f3-4f68-8bbe-2eda65a3d8c0", "embedding": null, "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/Location 1 \u2014 CityPark Central/"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9", "node_type": "4", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25"}, "hash": "f938ce3b057cc4cf3d6a9af0a500efc57579a1102372d024cc00dfa79f653a66", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "60375546-65a1-4c2f-b278-2b5a884c57f0", "node_type": "1", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/Location 1 \u2014 CityPark Central/"}, "hash": "162bfc4a6f04e02e1a66392fd36d66bfc62ffe1f20c8dce97982d13dd8ace492", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "48b63024-671a-4765-be73-8faadad1e2ad", "node_type": "1", "metadata": {"header_path": "/CityPark \u2014 Parking Facility Information/"}, "hash": "8cd40de40583c82a6cdd024fe8a200874299603ce743ce248bda348665448117", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "### Pricing \u2014 CityPark Central\n\n| Spot Type | Hourly Rate | Daily Rate (up to 24 h) |\n|-----------|-------------|--------------------------|\n| Standard (A1\u2013A5) | \u20ac2.50 / hour | \u20ac15.00 / day |\n| Premium covered (B1\u2013B3) | \u20ac4.00 / hour | \u20ac22.00 / day |\n\n---", "mimetype": "text/plain", "start_char_idx": 1687, "end_char_idx": 1941, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "48b63024-671a-4765-be73-8faadad1e2ad": {"__data__": {"id_": "48b63024-671a-4765-be73-8faadad1e2ad", "embedding": null, "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9", "node_type": "4", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25"}, "hash": "f938ce3b057cc4cf3d6a9af0a500efc57579a1102372d024cc00dfa79f653a66", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "09410bba-e5f3-4f68-8bbe-2eda65a3d8c0", "node_type": "1", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/Location 1 \u2014 CityPark Central/"}, "hash": "7139415b3699b1195d45a280f6483729dc42e33557036322bcbe8dd35ed12cc6", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "6274bec4-0c3e-49ac-89af-cfdfa1fd46af", "node_type": "1", "metadata": {"header_path": "/CityPark \u2014 Parking Facility Information/Location 2 \u2014 CityPark East (Railway Hub)/"}, "hash": "33c70ba1cb4875a26aaf605b2f00e21168e2da45baea554001b645392e84ce5e", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "## Location 2 \u2014 CityPark East (Railway Hub)\n\n**Address:** 3 Station Road, Maplewood East, 10045\n**Position:** Edge of the city, directly adjacent to Maplewood East Railway Terminal \u2014 the city's main freight and intercity transport hub.\n\n**Landmarks:**\n- Main entrance faces Maplewood East Railway Terminal (south exit)\n- 200 m from the East Ring Road interchange\n- Next to the Terminal Logistics Centre\n\n**Entrance:** Two separate vehicle gates \u2014 one for standard vehicles (Station Road), one for trucks and large vehicles (Terminal Lane, rear entrance).\n**Height restriction:** None \u2014 trucks and large vehicles fully supported.", "mimetype": "text/plain", "start_char_idx": 1943, "end_char_idx": 2571, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "6274bec4-0c3e-49ac-89af-cfdfa1fd46af": {"__data__": {"id_": "6274bec4-0c3e-49ac-89af-cfdfa1fd46af", "embedding": null, "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/Location 2 \u2014 CityPark East (Railway Hub)/"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9", "node_type": "4", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25"}, "hash": "f938ce3b057cc4cf3d6a9af0a500efc57579a1102372d024cc00dfa79f653a66", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "48b63024-671a-4765-be73-8faadad1e2ad", "node_type": "1", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/"}, "hash": "6c0110c0875b9da5c37939ddfb0ed12488dd0ebc448a3edf08afb4e07fbffa6a", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "891c4186-4cb2-4d6e-9cfb-3b2ffe2da199", "node_type": "1", "metadata": {"header_path": "/CityPark \u2014 Parking Facility Information/Location 2 \u2014 CityPark East (Railway Hub)/"}, "hash": "da620d530cf1b6411cf5c2caa1fa713a5d48c0997b210dc8bc68d438ba34eb55", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "### Parking Spots \u2014 CityPark East\n\n| Spot | Type     | Description                                               |\n|------|----------|-----------------------------------------------------------|\n| A1   | Standard | Open-air spot, suitable for standard-size cars            |\n| A2   | Standard | Open-air spot, suitable for standard-size cars            |\n| A3   | Standard | Open-air spot, suitable for standard-size cars            |\n| B1   | Premium  | Covered spot, suitable for cars and small vans            |\n| B2   | Premium  | Covered spot, suitable for cars and small vans            |\n| T1   | Truck    | Large open bay, suitable for trucks and heavy vehicles    |\n| T2   | Truck    | Large open bay, suitable for trucks and heavy vehicles    |\n| T3   | Truck    | Large open bay, suitable for trucks and heavy vehicles    |\n| T4   | Truck    | Large open bay, suitable for trucks and heavy vehicles    |\n| T5   | Truck    | Large open bay, suitable for trucks and heavy vehicles    |\n\n**Total: 10 spots** (3 standard, 2 premium, 5 truck bays).", "mimetype": "text/plain", "start_char_idx": 2573, "end_char_idx": 3627, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "891c4186-4cb2-4d6e-9cfb-3b2ffe2da199": {"__data__": {"id_": "891c4186-4cb2-4d6e-9cfb-3b2ffe2da199", "embedding": null, "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/Location 2 \u2014 CityPark East (Railway Hub)/"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9", "node_type": "4", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25"}, "hash": "f938ce3b057cc4cf3d6a9af0a500efc57579a1102372d024cc00dfa79f653a66", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "6274bec4-0c3e-49ac-89af-cfdfa1fd46af", "node_type": "1", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/Location 2 \u2014 CityPark East (Railway Hub)/"}, "hash": "2c88a9d8f3eac2212fc235cbc9c765b91a8c0d9b667abefbadd7f75b6fdfa860", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "5f7cd807-fcc7-4693-bf25-5498337c9c89", "node_type": "1", "metadata": {"header_path": "/CityPark \u2014 Parking Facility Information/"}, "hash": "ae71716bf6b426b5c5cb5bbeaf5a52ecb8d2fc09025c0e3616d6602479848ab8", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "### Pricing \u2014 CityPark East\n\n| Spot Type | Hourly Rate | Daily Rate (up to 24 h) |\n|-----------|-------------|--------------------------|\n| Standard (A1\u2013A3) | \u20ac2.00 / hour | \u20ac12.00 / day |\n| Premium covered (B1\u2013B2) | \u20ac3.50 / hour | \u20ac20.00 / day |\n| Truck bay (T1\u2013T5) | \u20ac6.00 / hour | \u20ac35.00 / day |\n\n---", "mimetype": "text/plain", "start_char_idx": 3629, "end_char_idx": 3932, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "5f7cd807-fcc7-4693-bf25-5498337c9c89": {"__data__": {"id_": "5f7cd807-fcc7-4693-bf25-5498337c9c89", "embedding": null, "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9", "node_type": "4", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25"}, "hash": "f938ce3b057cc4cf3d6a9af0a500efc57579a1102372d024cc00dfa79f653a66", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "891c4186-4cb2-4d6e-9cfb-3b2ffe2da199", "node_type": "1", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/Location 2 \u2014 CityPark East (Railway Hub)/"}, "hash": "701148190bbd7499422d187c3b93687c232118071744c068b1db55fec0ee9046", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "6b9bde10-1a0f-495c-80ea-1a7658ce6143", "node_type": "1", "metadata": {"header_path": "/CityPark \u2014 Parking Facility Information/"}, "hash": "b3425227406b4179a9ba39aa7abe5928595ead78655fb14de573b99434a120b2", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "## Billing Rules (Both Locations)\n\n- Hourly rate applies to bookings under 24 hours.\n- Daily rate applies to bookings of 24 hours or more per day; it is cheaper than 10+ hourly hours.\n- Payment is collected in full at the time of booking confirmation.\n- No partial refunds for unused time.\n- Multi-day bookings are charged as: number of full days \u00d7 daily rate.\n\n---", "mimetype": "text/plain", "start_char_idx": 3934, "end_char_idx": 4299, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "6b9bde10-1a0f-495c-80ea-1a7658ce6143": {"__data__": {"id_": "6b9bde10-1a0f-495c-80ea-1a7658ce6143", "embedding": null, "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9", "node_type": "4", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25"}, "hash": "f938ce3b057cc4cf3d6a9af0a500efc57579a1102372d024cc00dfa79f653a66", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "5f7cd807-fcc7-4693-bf25-5498337c9c89", "node_type": "1", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/"}, "hash": "b588a96837d093ff5409a1348fa93f8c811fd8ce904061c666856a2e4bbe2799", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "378e6a02-3720-4520-82c7-4e4b92cd8ccb", "node_type": "1", "metadata": {"header_path": "/CityPark \u2014 Parking Facility Information/"}, "hash": "7bf1399e75726fe321bbad15e2a1bf5274eb12d00d7f5442345ba9b42e75888a", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "## Rules & Regulations\n\n1. Reservations are required before arrival \u2014 walk-ins are not accepted.\n2. Arrive within 15 minutes of your reservation start time; late arrivals may forfeit the spot.\n3. The reserved spot may only be used by the vehicle specified at booking (by registration number).\n4. The following are strictly prohibited on the premises:\n   - Storage of flammable or hazardous materials\n   - Vehicle repairs or maintenance on site\n   - Overnight sleeping in vehicles\n5. CityPark is not responsible for theft, damage, or loss of vehicles or belongings.\n6. Vehicles parked without a valid reservation will be towed at the owner's expense.\n7. Trucks and oversized vehicles are only permitted at CityPark East (Location 2).\n\n---", "mimetype": "text/plain", "start_char_idx": 4301, "end_char_idx": 5038, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "378e6a02-3720-4520-82c7-4e4b92cd8ccb": {"__data__": {"id_": "378e6a02-3720-4520-82c7-4e4b92cd8ccb", "embedding": null, "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9", "node_type": "4", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25"}, "hash": "f938ce3b057cc4cf3d6a9af0a500efc57579a1102372d024cc00dfa79f653a66", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "6b9bde10-1a0f-495c-80ea-1a7658ce6143", "node_type": "1", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/"}, "hash": "f2bcb8e7a8be2dc428631c2883a9255cc91c3749ce96d0ae9df67695c3b44e02", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "a309bd34-f845-43d2-9bff-286b5c161ea2", "node_type": "1", "metadata": {"header_path": "/CityPark \u2014 Parking Facility Information/"}, "hash": "7078c38b83ff32788ca703b1c913e6c87d9450a5fa82a8c83e48a73b9f97fce1", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "## Booking Process\n\nReservations can only be made online through the CityPark website chat.\n\n**Steps to reserve:**\n\n1. Open the CityPark website chat assistant.\n2. Provide your details: full name, surname, vehicle registration number, desired location, spot type, and reservation period (start and end date/time).\n3. Submit the reservation request. An admin will review and approve or reject it.\n4. You will receive a confirmation message with a QR code once approved.\n5. On arrival, scan the QR code at the entrance gate to open it.\n\n**Cancellations:**\n- Cancellations made more than 1 hours before the reservation start time are eligible for a full refund.\n- Cancellations after 1 hours before the reservation are non-refundable.\n\n---", "mimetype": "text/plain", "start_char_idx": 5040, "end_char_idx": 5776, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "a309bd34-f845-43d2-9bff-286b5c161ea2": {"__data__": {"id_": "a309bd34-f845-43d2-9bff-286b5c161ea2", "embedding": null, "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9", "node_type": "4", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25"}, "hash": "f938ce3b057cc4cf3d6a9af0a500efc57579a1102372d024cc00dfa79f653a66", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "378e6a02-3720-4520-82c7-4e4b92cd8ccb", "node_type": "1", "metadata": {"file_path": "app\\rag\\seed_parking_info.md", "file_name": "seed_parking_info.md", "file_type": "text/markdown", "file_size": 6849, "creation_date": "2026-05-25", "last_modified_date": "2026-05-25", "header_path": "/CityPark \u2014 Parking Facility Information/"}, "hash": "1dc31c5f5f40117059a98879d59de23c7fef584ded78bef95a19df8e639f6dce", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "## FAQ\n\n**Q: Can I book at either location?**\nA: Yes. Choose the location that suits you when making a reservation. Trucks must use CityPark East.\n\n**Q: Can I extend my reservation while already parked?**\nA: Yes, if the spot is not reserved by another user after your booking, you can extend online through the website chat.\n\n**Q: What payment methods are accepted?**\nA: Credit and debit cards (Visa, Mastercard). Payment is processed online at time of booking.\n\n**Q: What happens if I arrive late?**\nA: You have a 15-minute grace period. After that, the spot may be released. Contact support immediately if delayed.\n\n**Q: Can I book for someone else?**\nA: Yes, but you must provide the actual vehicle registration number that will use the spot.\n\n**Q: Is the facility monitored?**\nA: Yes, CCTV cameras operate 24/7 at both locations. Footage is retained for 30 days.\n\n**Q: What if the entrance gate does not open?**\nA: Use the intercom at the gate or contact support through the website. Support is available 24/7.", "mimetype": "text/plain", "start_char_idx": 5778, "end_char_idx": 6792, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}}, "docstore/metadata": {"f168577c-d7c2-44d7-aaea-647513229f3a": {"doc_hash": "448e373cf73a113f7fe93813cbaf6aa4054600c6bda3143abcbadd6a49711366", "ref_doc_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9"}, "15cfaf15-28ad-40df-bcd1-e33f6f6e6915": {"doc_hash": "41f724e9e1d4d1382966cc2599113a2a951608b3b0efe4216b2698ee09d7e5e6", "ref_doc_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9"}, "42d0c5aa-8969-4528-8371-e81ee5ca2870": {"doc_hash": "219c2c25f29a2d741385bc01d2f114ead5596447ec9eb77ac97671df1654f6b2", "ref_doc_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9"}, "60375546-65a1-4c2f-b278-2b5a884c57f0": {"doc_hash": "162bfc4a6f04e02e1a66392fd36d66bfc62ffe1f20c8dce97982d13dd8ace492", "ref_doc_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9"}, "09410bba-e5f3-4f68-8bbe-2eda65a3d8c0": {"doc_hash": "7139415b3699b1195d45a280f6483729dc42e33557036322bcbe8dd35ed12cc6", "ref_doc_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9"}, "48b63024-671a-4765-be73-8faadad1e2ad": {"doc_hash": "6c0110c0875b9da5c37939ddfb0ed12488dd0ebc448a3edf08afb4e07fbffa6a", "ref_doc_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9"}, "6274bec4-0c3e-49ac-89af-cfdfa1fd46af": {"doc_hash": "2c88a9d8f3eac2212fc235cbc9c765b91a8c0d9b667abefbadd7f75b6fdfa860", "ref_doc_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9"}, "891c4186-4cb2-4d6e-9cfb-3b2ffe2da199": {"doc_hash": "701148190bbd7499422d187c3b93687c232118071744c068b1db55fec0ee9046", "ref_doc_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9"}, "5f7cd807-fcc7-4693-bf25-5498337c9c89": {"doc_hash": "b588a96837d093ff5409a1348fa93f8c811fd8ce904061c666856a2e4bbe2799", "ref_doc_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9"}, "6b9bde10-1a0f-495c-80ea-1a7658ce6143": {"doc_hash": "f2bcb8e7a8be2dc428631c2883a9255cc91c3749ce96d0ae9df67695c3b44e02", "ref_doc_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9"}, "378e6a02-3720-4520-82c7-4e4b92cd8ccb": {"doc_hash": "1dc31c5f5f40117059a98879d59de23c7fef584ded78bef95a19df8e639f6dce", "ref_doc_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9"}, "a309bd34-f845-43d2-9bff-286b5c161ea2": {"doc_hash": "a76d40d6842017d3a85f00651f1fe9909bdae158e6d58bf40d6805546b2aa990", "ref_doc_id": "72cd91d7-a323-4405-be0e-4d7cd547fbb9"}}}